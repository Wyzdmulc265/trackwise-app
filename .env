# Server Environment Configuration
# Copy to .env and update values as needed

# Database
DATABASE_URL=postgresql://trackwise_admin:trackwise_secure_123@localhost:5432/trackwise

# JWT Secrets (generate strong secrets in production)
JWT_SECRET=dev-secret-key-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-key-change-in-production

# Token Expiry (minutes)
JWT_EXPIRY=15
JWT_REFRESH_EXPIRY=10080 # 7 days in minutes

# Server
PORT=3001
NODE_ENV=development

# Frontend API URL (exposed to client via Vite)
VITE_API_URL=http://localhost:3001/api

# CORS (comma-separated origins for production)
CORS_ORIGIN=http://localhost:5173
